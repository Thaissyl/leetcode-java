{
  "files.encoding": "utf8",
  "java.debug.settings.console": "integratedTerminal",
  "java.debug.settings.vmArgs": "-Dfile.encoding=UTF-8 -Dsun.stdout.encoding=UTF-8 -Dsun.stderr.encoding=UTF-8",
  "terminal.integrated.defaultProfile.windows": "PowerShell UTF-8",
  "terminal.integrated.profiles.windows": {
    "PowerShell UTF-8": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-Command",
        "chcp 65001 | Out-Null; $utf8 = [System.Text.UTF8Encoding]::new($false); [Console]::InputEncoding = $utf8; [Console]::OutputEncoding = $utf8; $OutputEncoding = $utf8; Clear-Host"
      ]
    }
  },
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "java": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$workspaceRoot\\run.ps1\" \"$fullFileName\""
  }
}
